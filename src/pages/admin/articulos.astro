---
import AdminLayout from "../../layouts/AdminLayout.astro";
import DeleteModal from "../../components/admin/DeleteModal.astro";
import AdminHeader from "../../components/admin/AdminHeader.astro";
---

<AdminLayout title="Gestión de Artículos | Admin Panel">
    <!-- Quill.js CSS -->
    <link
        href="https://cdn.quilljs.com/1.3.6/quill.snow.css"
        rel="stylesheet"
    />

    <div
        class="flex h-screen overflow-hidden"
        style="display: none;"
        id="dashboard-content"
    >
        <!-- Sidebar Navigation -->
        <aside
            class="w-72 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col"
        >
            <div class="p-6 flex items-center gap-3">
                <div class="bg-primary rounded-lg p-2 text-white">
                    <span class="material-symbols-outlined text-2xl"
                        >bungalow</span
                    >
                </div>
                <div>
                    <h1 class="font-bold text-lg leading-tight">
                        Housing Admin
                    </h1>
                    <p class="text-xs text-slate-500 font-medium">
                        PREMIUM ESTATES
                    </p>
                </div>
            </div>
            <nav class="flex-1 px-4 mt-4 space-y-1">
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin"
                >
                    <span class="material-symbols-outlined">home</span>
                    <span class="font-medium">Modelos de Casas</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/destacados"
                >
                    <span class="material-symbols-outlined">star</span>
                    <span class="font-medium">Modelos Destacados</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-primary active-nav rounded-lg transition-colors"
                    href="/admin/articulos"
                >
                    <span
                        class="material-symbols-outlined"
                        style="font-variation-settings: 'FILL' 1;">article</span
                    >
                    <span class="font-medium">Artículos y Novedades</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors relative"
                    href="/admin/clientes"
                >
                    <span class="material-symbols-outlined">group</span>
                    <span class="font-medium">Clientes</span>
                    <span
                        id="nav-new-clients-badge"
                        class="hidden absolute right-4 bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full"
                        >NUEVOS</span
                    >
                </a>

                <div
                    class="pt-4 mt-4 border-t border-slate-100 dark:border-slate-800"
                >
                    <button
                        class="w-full flex items-center gap-3 px-4 py-3 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors mt-2"
                        id="logout-btn"
                    >
                        <span class="material-symbols-outlined">logout</span>
                        <span class="font-medium text-left">Cerrar Sesión</span>
                    </button>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <AdminHeader searchPlaceholder="Buscar artículos..." />

            <!-- Content Area -->
            <div class="flex-1 overflow-y-auto p-8">
                <!-- Breadcrumbs & Heading -->
                <div
                    class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8"
                >
                    <div>
                        <nav
                            class="flex items-center gap-2 text-sm text-slate-400 mb-2"
                        >
                            <a class="hover:text-primary" href="#">Admin</a>
                            <span class="material-symbols-outlined text-xs"
                                >chevron_right</span
                            >
                            <span
                                class="text-slate-600 dark:text-slate-300 font-medium"
                                >Artículos y Novedades</span
                            >
                        </nav>
                        <h2 class="text-3xl font-black tracking-tight">
                            Gestión de Artículos
                        </h2>
                        <p class="text-slate-500 mt-1">
                            Crea, edita y publica artículos para el blog.
                        </p>
                    </div>
                    <div class="flex flex-wrap items-center justify-end gap-3">
                        <button
                            onclick="openAddModal()"
                            class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all transform active:scale-95"
                        >
                            <span class="material-symbols-outlined"
                                >add_circle</span
                            >
                            Nuevo Artículo
                        </button>
                    </div>
                </div>

                <!-- Table Card -->
                <div
                    class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden"
                >
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr
                                    class="bg-slate-50/50 dark:bg-slate-800/50 text-slate-500 text-xs font-bold uppercase tracking-wider"
                                >
                                    <th class="px-6 py-5 w-24">Portada</th>
                                    <th class="px-6 py-5">Título</th>
                                    <th class="px-6 py-5">Fecha</th>
                                    <th class="px-6 py-5 text-right"
                                        >Acciones</th
                                    >
                                </tr>
                            </thead>
                            <tbody
                                id="articles-tbody"
                                class="divide-y divide-slate-100 dark:divide-slate-800"
                            >
                                <tr>
                                    <td
                                        colspan="4"
                                        style="text-align:center; padding: 2rem;"
                                        >Cargando artículos...</td
                                    >
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- SIDE MODAL (NUEVO/EDITAR ARTÍCULO) -->
    <div
        class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex justify-end opacity-0 pointer-events-none transition-opacity duration-300"
        id="add-modal"
    >
        <!-- Hacer el panel más ancho (max-w-4xl) para el editor de texto -->
        <div
            class="w-full max-w-4xl bg-white dark:bg-slate-900 h-full transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col shadow-2xl border-l border-slate-200 dark:border-slate-800 overflow-hidden"
            id="slide-panel"
        >
            <div
                class="px-6 py-5 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-white dark:bg-slate-900"
            >
                <h2
                    class="text-xl font-black text-slate-900 dark:text-white tracking-tight"
                    id="modal-title"
                >
                    Nuevo Artículo
                </h2>
                <div class="flex items-center gap-3">
                    <button
                        class="flex items-center justify-center w-8 h-8 rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-100 dark:hover:bg-slate-800 dark:hover:text-slate-300 transition-colors"
                        onclick="closeAddModal()"
                        type="button"
                    >
                        <span class="material-symbols-outlined text-[20px]"
                            >close</span
                        >
                    </button>
                    <button
                        class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded-xl text-sm font-bold shadow-md shadow-primary/20 transition-all transform active:scale-95"
                        onclick="submitAddForm()"
                        type="button"
                        id="save-article-btn"
                    >
                        <span class="material-symbols-outlined text-[18px]"
                            >save</span
                        >
                        Guardar
                    </button>
                </div>
            </div>

            <div
                class="flex-1 overflow-y-auto p-6 space-y-6 bg-slate-50/50 dark:bg-slate-900/50"
            >
                <form id="add-form" class="space-y-6">
                    <input type="hidden" id="article-id" />
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <!-- Left Column (Title & Media) -->
                        <div class="md:col-span-1 space-y-6">
                            <div
                                class="bg-white dark:bg-slate-800 p-5 rounded-2xl border border-slate-100 dark:border-slate-700 shadow-sm"
                            >
                                <h3
                                    class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4"
                                >
                                    Información Básica
                                </h3>
                                <div class="space-y-4">
                                    <div>
                                        <label
                                            class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-1.5"
                                            >Título del Artículo</label
                                        >
                                        <input
                                            type="text"
                                            id="title"
                                            class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm transition-all"
                                            placeholder="Ej: Las ventajas de la madera..."
                                            required
                                        />
                                    </div>
                                    <div>
                                        <label
                                            class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-1.5"
                                            >Resumen Corto</label
                                        >
                                        <textarea
                                            id="short_description"
                                            rows="3"
                                            class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm transition-all"
                                            placeholder="Breve introducción que aparecerá en la card..."
                                            required></textarea>
                                    </div>
                                </div>
                            </div>

                            <div
                                class="bg-white dark:bg-slate-800 p-5 rounded-2xl border border-slate-100 dark:border-slate-700 shadow-sm"
                            >
                                <h3
                                    class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4"
                                >
                                    Foto de Portada
                                </h3>
                                <div
                                    class="border-2 border-dashed border-primary/30 bg-primary/5 hover:bg-primary/10 rounded-xl p-6 text-center cursor-pointer transition-colors"
                                    onclick="document.getElementById('image-input').click()"
                                >
                                    <input
                                        type="file"
                                        id="image-input"
                                        accept="image/*"
                                        class="hidden"
                                        onchange="previewImage(event)"
                                    />
                                    <div
                                        id="upload-placeholder"
                                        class="flex flex-col items-center"
                                    >
                                        <span
                                            class="material-symbols-outlined text-primary text-3xl mb-2"
                                            >add_photo_alternate</span
                                        >
                                        <p
                                            class="text-sm font-bold text-slate-700 dark:text-slate-300"
                                        >
                                            Añadir foto
                                        </p>
                                    </div>
                                    <div
                                        id="image-preview-container"
                                        class="hidden relative w-full aspect-video rounded-lg overflow-hidden border border-slate-200 mt-2"
                                    >
                                        <img
                                            id="image-preview"
                                            src=""
                                            class="w-full h-full object-cover"
                                        />
                                        <button
                                            type="button"
                                            class="absolute top-2 right-2 bg-white/90 p-1.5 rounded-full text-red-500 shadow-sm flex items-center justify-center hover:bg-red-50"
                                            onclick="removeImage(event)"
                                        >
                                            <span
                                                class="material-symbols-outlined text-[16px]"
                                                >delete</span
                                            >
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column (Rich Text Editor) -->
                        <div class="md:col-span-2">
                            <div
                                class="bg-white dark:bg-slate-800 p-5 rounded-2xl border border-slate-100 dark:border-slate-700 shadow-sm h-full flex flex-col"
                            >
                                <h3
                                    class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4 flex items-center justify-between"
                                >
                                    <span>Contenido del Artículo</span>
                                    <span
                                        class="text-[10px] normal-case font-normal"
                                        >(Usa el formato estilo Word)</span
                                    >
                                </h3>
                                <div
                                    class="flex-1 min-h-[400px] flex flex-col rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700"
                                >
                                    <div
                                        id="editor-container"
                                        class="flex-1 bg-white"
                                    >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <DeleteModal />
</AdminLayout>

<!-- Quill.js JS -->
<script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<script is:inline>
    // Configuración Inicial e Inicialización de Quill
    let quill;
    let allArticles = [];
    let selectedFile = null;

    document.addEventListener("DOMContentLoaded", () => {
        const token = localStorage.getItem("admin_token");
        if (!token) {
            window.location.href = "/admin/login";
        } else {
            document.getElementById("dashboard-content").style.display = "flex";
            initQuill();
            loadArticles();
        }

        document.getElementById("logout-btn").addEventListener("click", () => {
            localStorage.removeItem("admin_token");
            window.location.href = "/admin/login";
        });
    });

    function initQuill() {
        // Toolbar options like Word
        const toolbarOptions = [
            [{ header: [1, 2, 3, 4, 5, 6, false] }],
            ["bold", "italic", "underline", "strike"], // toggled buttons
            [{ color: [] }, { background: [] }], // dropdown with defaults from theme
            [{ align: [] }],
            [{ list: "ordered" }, { list: "bullet" }],
            ["link", "image", "video"],
            ["clean"], // remove formatting button
        ];

        quill = new Quill("#editor-container", {
            theme: "snow",
            modules: {
                toolbar: toolbarOptions,
            },
            placeholder: "Escribe tu artículo aquí...",
        });
    }

    // Funciones API y UI
    async function loadArticles() {
        try {
            const res = await fetch("http://localhost:3001/api/articles");
            allArticles = await res.json();
            renderTable(allArticles);
        } catch (err) {
            console.error(err);
        }
    }

    function renderTable(data) {
        const tbody = document.getElementById("articles-tbody");
        tbody.innerHTML = "";

        if (data.length === 0) {
            tbody.innerHTML =
                '<tr><td colspan="4" style="text-align:center; padding: 2rem;">No hay artículos guardados.</td></tr>';
            return;
        }

        data.forEach((p) => {
            const tr = document.createElement("tr");
            tr.className =
                "hover:bg-slate-50/80 dark:hover:bg-slate-800/40 transition-colors";

            const imgHtml = p.image_url
                ? `<img src="${p.image_url}" class="w-full h-full object-cover" onerror="this.src=''" />`
                : `<div style="display:flex;align-items:center;justify-content:center;height:100%;"><span class="material-symbols-outlined text-slate-300">image</span></div>`;

            const dateStr = new Date(p.created_at).toLocaleDateString("es-ES", {
                year: "numeric",
                month: "short",
                day: "numeric",
            });

            tr.innerHTML = `
                <td class="px-6 py-4">
                    <div class="w-16 h-12 rounded-lg bg-slate-100 overflow-hidden shadow-sm">
                        ${imgHtml}
                    </div>
                </td>
                <td class="px-6 py-4">
                    <p class="font-bold text-slate-900 dark:text-slate-100">${p.title}</p>
                    <p class="text-xs text-slate-500 truncate max-w-xs">${p.short_description}</p>
                </td>
                <td class="px-6 py-4 text-sm text-slate-600">
                    ${dateStr}
                </td>
                <td class="px-6 py-4 text-right">
                    <div class="flex justify-end gap-2">
                        <button class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all" onclick='openEditModal(${JSON.stringify(p).replace(/'/g, "&#39;")})' title="Editar">
                            <span class="material-symbols-outlined">edit</span>
                        </button>
                        <button class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all" onclick="deleteArticle(${p.id})" title="Eliminar">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    </div>
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    function filterTable() {
        const q = document.getElementById("search-input").value.toLowerCase();
        const filtered = allArticles.filter((p) =>
            p.title.toLowerCase().includes(q),
        );
        renderTable(filtered);
    }

    // Modal Manager
    function resetForm() {
        document.getElementById("add-form").reset();
        document.getElementById("article-id").value = "";
        quill.root.innerHTML = ""; // Clear Rich text
        selectedFile = null;
        document
            .getElementById("upload-placeholder")
            .classList.remove("hidden");
        document
            .getElementById("image-preview-container")
            .classList.add("hidden");
        document.getElementById("image-preview").src = "";
        document.getElementById("modal-title").innerText = "Nuevo Artículo";
    }

    window.openAddModal = function () {
        resetForm();
        const modal = document.getElementById("add-modal");
        const panel = document.getElementById("slide-panel");
        modal.classList.remove("opacity-0", "pointer-events-none");
        panel.classList.remove("translate-x-full");
    };

    window.openEditModal = function (p) {
        resetForm();
        document.getElementById("article-id").value = p.id;
        document.getElementById("title").value = p.title;
        document.getElementById("short_description").value =
            p.short_description || "";
        quill.root.innerHTML = p.content || ""; // Load HTML into Quill

        if (p.image_url) {
            document
                .getElementById("upload-placeholder")
                .classList.add("hidden");
            document
                .getElementById("image-preview-container")
                .classList.remove("hidden");
            document.getElementById("image-preview").src = p.image_url;
        }

        document.getElementById("modal-title").innerText = "Editar Artículo";
        const modal = document.getElementById("add-modal");
        const panel = document.getElementById("slide-panel");
        modal.classList.remove("opacity-0", "pointer-events-none");
        panel.classList.remove("translate-x-full");
    };

    window.closeAddModal = function () {
        const modal = document.getElementById("add-modal");
        const panel = document.getElementById("slide-panel");
        panel.classList.add("translate-x-full");
        setTimeout(() => {
            modal.classList.add("opacity-0", "pointer-events-none");
        }, 300);
    };

    // Images
    window.previewImage = function (event) {
        if (event.target.files.length > 0) {
            selectedFile = event.target.files[0];
            const url = URL.createObjectURL(selectedFile);
            document
                .getElementById("upload-placeholder")
                .classList.add("hidden");
            document
                .getElementById("image-preview-container")
                .classList.remove("hidden");
            document.getElementById("image-preview").src = url;
        }
    };

    window.removeImage = function (event) {
        event.stopPropagation();
        selectedFile = null;
        document.getElementById("image-input").value = "";
        document
            .getElementById("upload-placeholder")
            .classList.remove("hidden");
        document
            .getElementById("image-preview-container")
            .classList.add("hidden");
        document.getElementById("image-preview").src = "";
    };

    // Database Actions
    window.submitAddForm = async function () {
        const title = document.getElementById("title").value;
        const short_description =
            document.getElementById("short_description").value;
        // Get HTML content from Quill
        const content = quill.root.innerHTML;

        if (
            !title.trim() ||
            !short_description.trim() ||
            quill.getText().trim() === ""
        ) {
            alert("Por favor rellena el título, resumen corto y el contenido.");
            return;
        }

        const id = document.getElementById("article-id").value;
        const isEditing = !!id;

        const formData = new FormData();
        formData.append("title", title);
        formData.append("short_description", short_description);
        formData.append("content", content); // HTML puro

        if (selectedFile) {
            formData.append("image", selectedFile);
        }

        const token = localStorage.getItem("admin_token");
        const btn = document.getElementById("save-article-btn");
        const oHtml = btn.innerHTML;
        btn.innerHTML = `<span class="material-symbols-outlined animate-spin">refresh</span>...`;
        btn.disabled = true;

        try {
            const method = isEditing ? "PUT" : "POST";
            const url = isEditing
                ? `http://localhost:3001/api/articles/${id}`
                : `http://localhost:3001/api/articles`;

            const res = await fetch(url, {
                method,
                headers: {
                    Authorization: `Bearer ${token}`,
                },
                body: formData,
            });

            if (res.ok) {
                closeAddModal();
                loadArticles();
            } else {
                const data = await res.json();
                alert(data.error || "Error al guardar");
            }
        } catch (error) {
            console.error(error);
            alert("Error de conexión");
        } finally {
            btn.innerHTML = oHtml;
            btn.disabled = false;
        }
    };

    window.deleteArticle = async function (id) {
        showGlobalDeleteModal(
            "¿Borrar artículo?",
            "¿Borrar este artículo permanentemente?",
            async () => {
                const token = localStorage.getItem("admin_token");
                try {
                    const res = await fetch(
                        `http://localhost:3001/api/articles/${id}`,
                        {
                            method: "DELETE",
                            headers: {
                                Authorization: `Bearer ${token}`,
                            },
                        },
                    );
                    if (res.ok) {
                        loadArticles();
                    } else {
                        alert("Error borrando el artículo");
                    }
                } catch (error) {
                    console.error(error);
                    alert("Error de red");
                }
            },
        );
    };
</script>

<style>
    /* Override Quill Toolbar styling to match Tailwind UI */
    .ql-toolbar.ql-snow {
        border-top-left-radius: 0.75rem;
        border-top-right-radius: 0.75rem;
        border-color: #e2e8f0;
        background-color: #f8fafc;
        padding: 12px;
    }
    .ql-container.ql-snow {
        border-bottom-left-radius: 0.75rem;
        border-bottom-right-radius: 0.75rem;
        border-color: #e2e8f0;
        font-family: "Inter", sans-serif;
        font-size: 15px;
    }
    .dark .ql-toolbar.ql-snow,
    .dark .ql-container.ql-snow {
        border-color: #334155;
    }
    .dark .ql-toolbar.ql-snow {
        background-color: #1e293b;
    }
    .dark .ql-snow .ql-stroke {
        stroke: #94a3b8;
    }
    .dark .ql-snow .ql-fill,
    .dark .ql-snow .ql-stroke.ql-fill {
        fill: #94a3b8;
    }
    .dark .ql-snow .ql-picker {
        color: #94a3b8;
    }
</style>
