---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Login | Housing Admin">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div
            class="max-w-md w-full bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 p-8 sm:p-10 relative overflow-hidden"
        >
            <!-- Decorative Background Element -->
            <div
                class="absolute -top-24 -right-24 w-48 h-48 bg-primary/10 rounded-full blur-3xl pointer-events-none"
            >
            </div>

            <div class="flex items-center gap-3 mb-8 relative z-10">
                <div
                    class="bg-primary rounded-xl p-2.5 text-white shadow-lg shadow-primary/30"
                >
                    <span
                        class="material-symbols-outlined text-3xl leading-none"
                        >bungalow</span
                    >
                </div>
                <div>
                    <h1
                        class="font-bold text-2xl tracking-tight text-slate-900 dark:text-white"
                    >
                        Admin Access
                    </h1>
                    <p class="text-sm text-slate-500 font-medium">
                        PREMIUM ESTATES
                    </p>
                </div>
            </div>

            <form id="login-form" class="space-y-6 relative z-10">
                <div class="space-y-1.5">
                    <label
                        class="block text-sm font-semibold text-slate-700 dark:text-slate-300"
                        >Correo Electrónico</label
                    >
                    <div class="relative">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"
                            >mail</span
                        >
                        <input
                            type="email"
                            id="email"
                            required
                            class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/20 text-sm transition-all text-slate-900 dark:text-slate-100 placeholder-slate-400"
                            placeholder="admin@tayga.com"
                        />
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label
                        class="block text-sm font-semibold text-slate-700 dark:text-slate-300"
                        >Contraseña</label
                    >
                    <div class="relative">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"
                            >lock</span
                        >
                        <input
                            type="password"
                            id="password"
                            required
                            class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/20 text-sm transition-all text-slate-900 dark:text-slate-100"
                            placeholder="••••••••"
                        />
                    </div>
                </div>

                <div
                    id="error-msg"
                    class="text-red-500 text-sm font-medium text-center min-h-[20px]"
                >
                </div>

                <button
                    type="submit"
                    class="w-full bg-primary hover:bg-primary/90 text-white py-3.5 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all transform active:scale-95 flex justify-center items-center gap-2"
                >
                    <span class="material-symbols-outlined text-xl">login</span>
                    Iniciar Sesión
                </button>
            </form>
        </div>
    </div>
</AdminLayout>

<script is:inline>
    // Verificar si ya está logueado
    if (localStorage.getItem("admin_token")) {
        window.location.href = "/admin";
    }

    document
        .getElementById("login-form")
        .addEventListener("submit", async (e) => {
            e.preventDefault();
            const email = document.getElementById("email").value;
            const password = document.getElementById("password").value;
            const errorMsg = document.getElementById("error-msg");

            try {
                const res = await fetch(
                    "http://localhost:3001/api/auth/login",
                    {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ email, password }),
                    },
                );
                const data = await res.json();

                if (res.ok) {
                    localStorage.setItem("admin_token", data.token);
                    window.location.href = "/admin";
                } else {
                    errorMsg.textContent =
                        data.error || "Autenticación fallida";
                }
            } catch (err) {
                errorMsg.textContent =
                    "Error de conexión con el servidor backend";
            }
        });
</script>
