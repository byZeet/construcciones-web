---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminHeader from "../../components/admin/AdminHeader.astro";
---

<AdminLayout title="Modelos Destacados | Admin Panel">
    <div
        class="flex h-screen overflow-hidden"
        style="display: none;"
        id="dashboard-content"
    >
        <!-- Sidebar Navigation -->
        <aside
            class="w-72 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col"
        >
            <div class="p-6 flex items-center gap-3">
                <div class="bg-primary rounded-lg p-2 text-white">
                    <span class="material-symbols-outlined text-2xl"
                        >bungalow</span
                    >
                </div>
                <div>
                    <h1 class="font-bold text-lg leading-tight">
                        Housing Admin
                    </h1>
                    <p class="text-xs text-slate-500 font-medium">
                        PREMIUM ESTATES
                    </p>
                </div>
            </div>
            <nav class="flex-1 px-4 mt-4 space-y-1">
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin"
                >
                    <span class="material-symbols-outlined">home</span>
                    <span class="font-medium">Modelos de Casas</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-primary active-nav rounded-lg transition-colors"
                    href="/admin/destacados"
                >
                    <span
                        class="material-symbols-outlined"
                        style="font-variation-settings: 'FILL' 1;">star</span
                    >
                    <span class="font-medium">Modelos Destacados</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/articulos"
                >
                    <span class="material-symbols-outlined">article</span>
                    <span class="font-medium">Artículos y Novedades</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors relative"
                    href="/admin/clientes"
                >
                    <span class="material-symbols-outlined">group</span>
                    <span class="font-medium">Clientes</span>
                    <span
                        id="nav-new-clients-badge"
                        class="hidden absolute right-4 bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full"
                        >NUEVOS</span
                    >
                </a>

                <div
                    class="pt-4 mt-4 border-t border-slate-100 dark:border-slate-800"
                >
                    <button
                        class="w-full flex items-center gap-3 px-4 py-3 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors mt-2"
                        id="logout-btn"
                    >
                        <span class="material-symbols-outlined">logout</span>
                        <span class="font-medium text-left">Cerrar Sesión</span>
                    </button>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <AdminHeader showSearch={false} />

            <!-- Content Area -->
            <div class="flex-1 overflow-y-auto p-8 relative">
                <!-- Breadcrumbs & Heading -->
                <div
                    class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8"
                >
                    <div>
                        <nav
                            class="flex items-center gap-2 text-sm text-slate-400 mb-2"
                        >
                            <a class="hover:text-primary" href="#">Admin</a>
                            <span class="material-symbols-outlined text-xs"
                                >chevron_right</span
                            >
                            <span
                                class="text-slate-600 dark:text-slate-300 font-medium"
                                >Modelos Destacados</span
                            >
                        </nav>
                        <h2 class="text-3xl font-black tracking-tight">
                            Modelos Destacados
                        </h2>
                        <p class="text-slate-500 mt-1">
                            Selecciona hasta 4 Modelos Exclusivos y 4 Productos
                            Top para mostrar en la web.
                        </p>
                    </div>
                    <div class="flex flex-wrap items-center justify-end gap-3">
                        <button
                            id="save-btn"
                            onclick="saveFeatured()"
                            class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all transform active:scale-95"
                        >
                            <span class="material-symbols-outlined">save</span>
                            Guardar Cambios
                        </button>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="grid grid-cols-2 gap-6 mb-8">
                    <div
                        class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center justify-between"
                    >
                        <div>
                            <p
                                class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-1"
                            >
                                Modelos Exclusivos
                            </p>
                            <p
                                class="text-3xl font-black text-slate-900 dark:text-white"
                            >
                                <span id="count-exclusives">0</span>/4
                            </p>
                        </div>
                        <div
                            class="w-12 h-12 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center"
                        >
                            <span class="material-symbols-outlined text-2xl"
                                >diamond</span
                            >
                        </div>
                    </div>
                    <div
                        class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center justify-between"
                    >
                        <div>
                            <p
                                class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-1"
                            >
                                Productos Top
                            </p>
                            <p
                                class="text-3xl font-black text-slate-900 dark:text-white"
                            >
                                <span id="count-top">0</span>/4
                            </p>
                        </div>
                        <div
                            class="w-12 h-12 rounded-full bg-rose-100 text-rose-600 flex items-center justify-center"
                        >
                            <span class="material-symbols-outlined text-2xl"
                                >local_fire_department</span
                            >
                        </div>
                    </div>
                </div>

                <!-- Table Card -->
                <div
                    class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden"
                >
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr
                                    class="bg-slate-50/50 dark:bg-slate-800/50 text-slate-500 text-xs font-bold uppercase tracking-wider"
                                >
                                    <th class="px-6 py-5 w-24">Vista</th>
                                    <th class="px-6 py-5">Nombre del Modelo</th>
                                    <th class="px-6 py-5 text-center"
                                        >Exclusivo</th
                                    >
                                    <th class="px-6 py-5 text-center">Top</th>
                                </tr>
                            </thead>
                            <tbody
                                id="properties-tbody"
                                class="divide-y divide-slate-100 dark:divide-slate-800"
                            >
                                <tr>
                                    <td
                                        colspan="4"
                                        style="text-align:center; padding: 2rem;"
                                        >Cargando propiedades...</td
                                    >
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</AdminLayout>

<script is:inline>
    const token = localStorage.getItem("admin_token");

    if (!token) {
        window.location.href = "/admin/login";
    } else {
        document.getElementById("dashboard-content").style.display = "flex";
        loadProperties();
    }

    document.getElementById("logout-btn").addEventListener("click", () => {
        localStorage.removeItem("admin_token");
        window.location.href = "/admin/login";
    });

    let allProperties = [];

    async function loadProperties() {
        try {
            const res = await fetch("http://localhost:3001/api/properties");
            allProperties = await res.json();
            renderTable();
            updateCounts();
        } catch (err) {
            console.error(err);
            alert("Error cargando propiedades");
        }
    }

    function renderTable() {
        const tbody = document.getElementById("properties-tbody");
        tbody.innerHTML = "";

        if (allProperties.length === 0) {
            tbody.innerHTML =
                '<tr><td colspan="4" style="text-align:center; padding: 2rem;">No hay propiedades guardadas.</td></tr>';
            return;
        }

        allProperties.forEach((p) => {
            const tr = document.createElement("tr");
            tr.className =
                "hover:bg-slate-50/80 dark:hover:bg-slate-800/40 transition-colors";

            const imgHtml = p.image_url
                ? `<img src="${p.image_url}" class="w-full h-full object-cover" onerror="this.src=''" />`
                : `<div style="display:flex;align-items:center;justify-content:center;height:100%;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg></div>`;

            tr.innerHTML = `
                <td class="px-6 py-4">
                    <div class="w-16 h-12 rounded-lg bg-slate-100 overflow-hidden shadow-sm">
                        ${imgHtml}
                    </div>
                </td>
                <td class="px-6 py-4">
                    <p class="font-bold text-slate-900 dark:text-slate-100">${p.title}</p>
                </td>
                <td class="px-6 py-4 text-center">
                    <input class="w-5 h-5 rounded border-slate-300 text-amber-500 focus:ring-amber-500/20 cursor-pointer exclusive-cb" type="checkbox" data-id="${p.id}" ${p.is_exclusive ? "checked" : ""} onchange="handleToggle(this, 'exclusive')"/>
                </td>
                <td class="px-6 py-4 text-center">
                    <input class="w-5 h-5 rounded border-slate-300 text-rose-500 focus:ring-rose-500/20 cursor-pointer top-cb" type="checkbox" data-id="${p.id}" ${p.is_top ? "checked" : ""} onchange="handleToggle(this, 'top')"/>
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    function handleToggle(checkbox, type) {
        const selector =
            type === "exclusive" ? ".exclusive-cb:checked" : ".top-cb:checked";
        const checkedCount = document.querySelectorAll(selector).length;

        if (checkedCount > 4) {
            alert(
                `No puedes seleccionar más de 4 propiedades como ${type === "exclusive" ? "Exclusivas" : "Top"}.`,
            );
            checkbox.checked = false;
        }
        updateCounts();
    }

    function updateCounts() {
        document.getElementById("count-exclusives").innerText =
            document.querySelectorAll(".exclusive-cb:checked").length;
        document.getElementById("count-top").innerText =
            document.querySelectorAll(".top-cb:checked").length;
    }

    window.saveFeatured = async function () {
        const btn = document.getElementById("save-btn");
        const originalHtml = btn.innerHTML;

        const exclusiveIds = Array.from(
            document.querySelectorAll(".exclusive-cb:checked"),
        ).map((cb) => parseInt(cb.dataset.id));
        const topIds = Array.from(
            document.querySelectorAll(".top-cb:checked"),
        ).map((cb) => parseInt(cb.dataset.id));

        try {
            btn.innerHTML = `<span class="material-symbols-outlined animate-spin">refresh</span> Guardando...`;
            btn.disabled = true;

            const res = await fetch(
                "http://localhost:3001/api/properties/featured/update",
                {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json",
                        Authorization: `Bearer ${token}`,
                    },
                    body: JSON.stringify({ exclusiveIds, topIds }),
                },
            );

            if (res.ok) {
                // Show success feedback
                btn.innerHTML = `<span class="material-symbols-outlined">check</span> Guardado`;
                btn.classList.replace("bg-primary", "bg-green-500");
                btn.classList.replace(
                    "hover:bg-primary/90",
                    "hover:bg-green-600",
                );

                setTimeout(() => {
                    btn.innerHTML = originalHtml;
                    btn.classList.replace("bg-green-500", "bg-primary");
                    btn.classList.replace(
                        "hover:bg-green-600",
                        "hover:bg-primary/90",
                    );
                    btn.disabled = false;
                }, 2000);
            } else {
                const err = await res.json();
                alert(err.error || "Error al guardar");
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        } catch (error) {
            console.error(error);
            alert("Error de conexión");
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }
    };
</script>
