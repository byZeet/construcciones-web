---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import DeleteModal from "../../../components/admin/DeleteModal.astro";
import AdminHeader from "../../../components/admin/AdminHeader.astro";
---

<AdminLayout title="Solicitudes de Clientes | Admin Panel">
    <div
        class="flex h-screen overflow-hidden"
        style="display: none;"
        id="dashboard-content"
    >
        <!-- Sidebar Navigation -->
        <aside
            class="w-72 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col"
        >
            <div class="p-6 flex items-center gap-3">
                <div class="bg-primary rounded-lg p-2 text-white">
                    <span class="material-symbols-outlined text-2xl"
                        >bungalow</span
                    >
                </div>
                <div>
                    <h1 class="font-bold text-lg leading-tight">
                        Housing Admin
                    </h1>
                    <p class="text-xs text-slate-500 font-medium">
                        PREMIUM ESTATES
                    </p>
                </div>
            </div>

            <nav class="flex-1 px-4 mt-4 space-y-1">
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin"
                >
                    <span class="material-symbols-outlined">home</span>
                    <span class="font-medium">Modelos de Casas</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/destacados"
                >
                    <span class="material-symbols-outlined">star</span>
                    <span class="font-medium">Modelos Destacados</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors"
                    href="/admin/articulos"
                >
                    <span class="material-symbols-outlined">article</span>
                    <span class="font-medium">Artículos y Novedades</span>
                </a>
                <a
                    class="flex items-center gap-3 px-4 py-3 text-primary active-nav rounded-lg transition-colors relative"
                    href="/admin/clientes"
                >
                    <span
                        class="material-symbols-outlined"
                        style="font-variation-settings: 'FILL' 1;">group</span
                    >
                    <span class="font-medium">Clientes</span>
                </a>

                <div
                    class="pt-4 mt-4 border-t border-slate-100 dark:border-slate-800"
                >
                    <button
                        class="w-full flex items-center gap-3 px-4 py-3 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors mt-2"
                        id="logout-btn"
                    >
                        <span class="material-symbols-outlined">logout</span>
                        <span class="font-medium text-left">Cerrar Sesión</span>
                    </button>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col overflow-hidden">
            <AdminHeader
                searchPlaceholder="Buscar por cliente, email o modelo..."
            />

            <!-- Content Area -->
            <div class="flex-1 overflow-y-auto p-8 relative">
                <!-- Breadcrumbs & Heading -->
                <div
                    class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8"
                >
                    <div>
                        <nav
                            class="flex items-center gap-2 text-sm text-slate-400 mb-2"
                        >
                            <a class="hover:text-primary" href="/admin">Admin</a
                            >
                            <span class="material-symbols-outlined text-xs"
                                >chevron_right</span
                            >
                            <span
                                class="text-slate-600 dark:text-slate-300 font-medium"
                                >Clientes</span
                            >
                        </nav>
                        <h2 class="text-3xl font-black tracking-tight">
                            Presupuestos y Clientes
                        </h2>
                        <p class="text-slate-500 mt-1">
                            Gestiona las solicitudes de presupuesto recibidas
                            desde la landing page.
                        </p>
                    </div>
                </div>

                <!-- Table Card -->
                <div
                    class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden"
                >
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr
                                    class="bg-slate-50/50 dark:bg-slate-800/50 text-slate-500 text-xs font-bold uppercase tracking-wider"
                                >
                                    <th class="px-6 py-5">Cliente</th>
                                    <th class="px-6 py-5">Contacto</th>
                                    <th class="px-6 py-5">Modelo de interés</th>
                                    <th class="px-6 py-5 text-center">Estado</th
                                    >
                                    <th class="px-6 py-5 text-right"
                                        >Acciones</th
                                    >
                                </tr>
                            </thead>
                            <tbody
                                id="clients-tbody"
                                class="divide-y divide-slate-100 dark:divide-slate-800"
                            >
                                <tr>
                                    <td
                                        colspan="5"
                                        style="text-align:center; padding: 2rem;"
                                        >Cargando solicitudes...</td
                                    >
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <DeleteModal />
</AdminLayout>

<script is:inline>
    const token = localStorage.getItem("admin_token");
    if (!token) {
        window.location.href = "/admin/login";
    } else {
        document.getElementById("dashboard-content").style.display = "flex";
        loadClients();
    }

    document.getElementById("logout-btn").addEventListener("click", () => {
        localStorage.removeItem("admin_token");
        window.location.href = "/admin/login";
    });

    let allClients = [];

    async function loadClients() {
        try {
            const res = await fetch("http://localhost:3001/api/clients", {
                headers: { Authorization: `Bearer ${token}` },
            });
            if (!res.ok) throw new Error("Error loading clients");
            allClients = await res.json();
            renderTable(allClients);
        } catch (err) {
            console.error(err);
            document.getElementById("clients-tbody").innerHTML =
                '<tr><td colspan="5" style="text-align:center; padding: 2rem; color:red;">No se pudieron cargar los datos.</td></tr>';
        }
    }

    function renderTable(data = allClients) {
        const tbody = document.getElementById("clients-tbody");
        tbody.innerHTML = "";

        if (data.length === 0) {
            tbody.innerHTML =
                '<tr><td colspan="5" style="text-align:center; padding: 2rem;">No hay solicitudes de clientes.</td></tr>';
            return;
        }

        data.forEach((client) => {
            const tr = document.createElement("tr");
            tr.className =
                "hover:bg-slate-50/80 dark:hover:bg-slate-800/40 transition-colors";

            // Status Badge
            const isNew = client.status === "new";
            const statusBadge = isNew
                ? '<span class="px-3 py-1 rounded-full text-[11px] font-bold bg-primary text-white border border-blue-600 uppercase">Nuevo</span>'
                : '<span class="px-3 py-1 rounded-full text-[11px] font-bold bg-slate-100 text-slate-500 border border-slate-200 uppercase">Leído</span>';

            // Format phone and email
            const contactHtml = `
                <div class="text-sm">
                    <div><a href="mailto:${client.email}" class="text-primary hover:underline">${client.email}</a></div>
                    ${client.phone ? `<div class="text-slate-500">${client.phone}</div>` : ""}
                </div>
            `;

            // Format date
            const dateObj = new Date(client.created_at);
            const dateStr =
                dateObj.toLocaleDateString("es-ES") +
                " " +
                dateObj.toLocaleTimeString("es-ES", {
                    hour: "2-digit",
                    minute: "2-digit",
                });

            tr.innerHTML = `
                <td class="px-6 py-4">
                    <p class="font-bold text-slate-900 dark:text-slate-100">${client.name}</p>
                    <p class="text-xs text-slate-400">${dateStr}</p>
                </td>
                <td class="px-6 py-4">
                    ${contactHtml}
                </td>
                <td class="px-6 py-4">
                    <span class="font-medium text-slate-700 dark:text-slate-300">${client.model || "-"}</span>
                </td>
                <td class="px-6 py-4 text-center">
                    ${statusBadge}
                </td>
                <td class="px-6 py-4 text-right">
                    <div class="flex justify-end gap-2">
                        <a href="/admin/clientes/detalle?id=${client.id}" class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Ver Solicitud">
                            <span class="material-symbols-outlined">visibility</span>
                        </a>
                        <button class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all" onclick="deleteClient(${client.id})" title="Eliminar">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    </div>
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    function filterTable() {
        const q = document.getElementById("search-input").value.toLowerCase();
        const filtered = allClients.filter(
            (c) =>
                (c.name && c.name.toLowerCase().includes(q)) ||
                (c.email && c.email.toLowerCase().includes(q)) ||
                (c.phone && c.phone.toLowerCase().includes(q)) ||
                (c.model && c.model.toLowerCase().includes(q)),
        );
        renderTable(filtered);
    }

    window.deleteClient = async function (id) {
        showGlobalDeleteModal(
            "¿Eliminar solicitud?",
            "¿Eliminar esta solicitud de presupuesto de forma permanente?",
            async () => {
                try {
                    const res = await fetch(
                        `http://localhost:3001/api/clients/${id}`,
                        {
                            method: "DELETE",
                            headers: { Authorization: `Bearer ${token}` },
                        },
                    );
                    if (res.ok) {
                        loadClients();
                    } else {
                        alert("Error al eliminar la solicitud");
                    }
                } catch (e) {
                    console.error(e);
                    alert("Error de conexión");
                }
            },
        );
    };
</script>
