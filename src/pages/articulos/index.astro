---
import Layout from "../../layouts/Layout.astro";
import "../../styles/catalog.css"; // Reusing some catalog styles for grid

let articles: any[] = [];

try {
    const res = await fetch("http://localhost:3001/api/articles");
    if (res.ok) {
        articles = await res.json();
    }
} catch (e) {
    console.warn("Could not fetch articles", e);
}
---

<Layout title="Artículos y Novedades | Tayga">
    <div
        class="catalog-container"
        style="display: block; max-width: 1200px; margin: 0 auto;"
    >
        <!-- Header -->
        <header
            class="catalog-header"
            style="text-align: center; margin-bottom: 4rem;"
        >
            <span
                class="eyebrow"
                style="color: #666; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;"
                >Nuestro Blog</span
            >
            <h1
                class="catalog-title"
                style="font-size: 2.5rem; color: #1a1a1a; margin-top: 0.5rem;"
            >
                Artículos y Novedades
            </h1>
            <p
                style="color: #666; margin-top: 1rem; max-width: 600px; margin-left: auto; margin-right: auto; line-height: 1.6;"
            >
                Descubre inspiración, consejos de arquitectura sostenible y las
                últimas novedades de Tayga Construcciones.
            </p>
        </header>

        <main
            class="products-grid"
            style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem;"
        >
            {
                articles.length === 0 ? (
                    <div style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; color: #666;">
                        <p>Aún no hay artículos publicados. ¡Vuelve pronto!</p>
                    </div>
                ) : (
                    articles.map((article: any) => (
                        <article
                            class="product-card"
                            style="display: flex; flex-direction: column; height: 100%;"
                        >
                            <a
                                href={`/articulos/${article.id}`}
                                class="card-image-wrapper"
                                style="height: 240px;"
                            >
                                <img
                                    src={
                                        article.image_url ||
                                        "/images/img_fondo1.jpg"
                                    }
                                    alt={article.title}
                                    class="card-image"
                                    loading="lazy"
                                    style="width: 100%; height: 100%; object-fit: cover;"
                                />
                            </a>

                            <div
                                class="card-info"
                                style="flex: 1; display: flex; flex-direction: column;"
                            >
                                <div style="margin-bottom: 1rem;">
                                    <span style="font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">
                                        {new Date(
                                            article.created_at,
                                        ).toLocaleDateString("es-ES", {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        })}
                                    </span>
                                </div>
                                <h2
                                    class="card-title"
                                    style="font-size: 1.25rem; font-weight: 700; line-height: 1.4; margin-bottom: 0.75rem; color: #1a1a1a;"
                                >
                                    <a
                                        href={`/articulos/${article.id}`}
                                        style="text-decoration: none; color: inherit;"
                                    >
                                        {article.title}
                                    </a>
                                </h2>
                                <p style="color: #666; font-size: 0.95rem; line-height: 1.6; flex: 1; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                    {article.short_description}
                                </p>

                                <div
                                    class="card-footer"
                                    style="padding-top: 1.5rem; margin-top: 1.5rem; border-top: 1px solid #eee;"
                                >
                                    <a
                                        href={`/articulos/${article.id}`}
                                        style="color: #bfa17c; font-weight: 600; font-size: 0.9rem; text-decoration: none; display: inline-flex; items-center; gap: 0.5rem; transition: color 0.2s;"
                                        onmouseover="this.style.color='#8c7457'"
                                        onmouseout="this.style.color='#bfa17c'"
                                    >
                                        Leer más <span>→</span>
                                    </a>
                                </div>
                            </div>
                        </article>
                    ))
                )
            }
        </main>
    </div>
</Layout>
