---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    let articles = [];
    try {
        const res = await fetch("http://localhost:3001/api/articles");
        if (res.ok) {
            articles = await res.json();
        }
    } catch (e) {
        console.error("Failed to fetch articles for static paths", e);
    }
    return articles.map((article: any) => ({
        params: { id: article.id.toString() },
    }));
}

const { id } = Astro.params;

let article: any = null;

try {
    const res = await fetch(`http://localhost:3001/api/articles/${id}`);
    if (res.ok) {
        article = await res.json();
    }
} catch (e) {
    console.warn("Could not fetch article", e);
}

if (!article) {
    return Astro.redirect("/404");
}
---

<Layout title={`${article.title} | Tayga Blog`}>
    <article class="article-detail">
        <!-- Hero Section del Artículo -->
        <header
            class="article-hero"
            style={`background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)), url('${article.image_url || "/images/img_fondo1.jpg"}');`}
        >
            <div class="container article-hero-content">
                <a href="/articulos" class="back-link"
                    >← Volver a todos los artículos</a
                >

                <div class="meta-info">
                    <span class="date"
                        >{
                            new Date(article.created_at).toLocaleDateString(
                                "es-ES",
                                {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                },
                            )
                        }</span
                    >
                    <span class="category">Tayga News</span>
                </div>

                <h1 class="title">{article.title}</h1>
                <p class="subtitle">{article.short_description}</p>
            </div>
        </header>

        <!-- Contenido Rico -->
        <div class="container article-body-container">
            <div class="article-content ql-editor" set:html={article.content} />
        </div>
    </article>
</Layout>

<!-- Asegurarnos de que los estilos del editor ricos (Quill) se apliquen al ver la página pública -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />

<style>
    .article-hero {
        padding: 8rem 0 6rem;
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        color: white;
        text-align: center;
        margin-bottom: 4rem;
    }

    .article-hero-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .back-link {
        display: inline-block;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: white;
    }

    .meta-info {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.9);
    }

    .category {
        background: #bfa17c;
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 4px;
    }

    .title {
        font-family: inherit;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .subtitle {
        font-size: 1.2rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 300;
    }

    .article-body-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 2rem 6rem;
    }

    /* Sobrescribir estilos genéricos de Quill para la vista pública */
    .article-content.ql-editor {
        padding: 0;
        overflow-y: visible;
        font-size: 1.1rem;
        line-height: 1.8;
        color: #333;
        font-family: "Inter", sans-serif;
    }

    .article-content.ql-editor h1,
    .article-content.ql-editor h2,
    .article-content.ql-editor h3 {
        color: #1a1a1a;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        font-weight: 700;
        line-height: 1.3;
    }

    .article-content.ql-editor h2 {
        font-size: 2rem;
    }
    .article-content.ql-editor h3 {
        font-size: 1.5rem;
    }

    .article-content.ql-editor p {
        margin-bottom: 1.5rem;
    }

    .article-content.ql-editor img {
        max-width: 100%;
        border-radius: 8px;
        margin: 2rem 0;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    .article-content.ql-editor ul,
    .article-content.ql-editor ol {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }

    .article-content.ql-editor li {
        margin-bottom: 0.5rem;
    }

    .article-content.ql-editor a {
        color: #bfa17c;
        text-decoration: underline;
        text-underline-offset: 4px;
    }
</style>
