import Layout from "../../layouts/Layout.astro";
import "../../styles/model-detail.css";

export async function getStaticPaths() {
    let properties = [];
    try {
        const res = await fetch("http://localhost:3001/api/properties");
        if (res.ok) {
            properties = await res.json();
        }
    } catch (e) {
        console.error("Failed to fetch properties for static paths", e);
    }

    return properties.map((p: any) => {
        const gallery = p.images
            ? p.images
                  .filter((img: any) => img.is_main === 0)
                  .map((img: any) => img.image_url)
            : [];
        return {
            params: { id: p.id.toString() },
            props: {
                modelData: p,
                images: {
                    main: p.image_url || "/images/img_fondo1.jpg",
                    plan: null,
                    gallery: gallery,
                },
            },
        };
    });
}

const { id } = Astro.params;
const { images, modelData } = Astro.props as { images: any; modelData: any };
const name = modelData.title;
const specs = {
    surface: `${modelData.area} m²`,
    rooms: modelData.bedrooms,
    price: modelData.price,
};

// Get Recommendations (random 4 models from the database excluding the current one)
let recommendedModels = [];
try {
    const res = await fetch("http://localhost:3001/api/properties");
    if (res.ok) {
        const allProperties = await res.json();
        const others = allProperties.filter((p: any) => p.id.toString() !== id);
        recommendedModels = others.sort(() => 0.5 - Math.random()).slice(0, 10);
    }
} catch (e) {
    console.error(e);
}
