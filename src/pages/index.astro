---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ComparisonSection from "../components/ComparisonSection.astro";
import ProcessTimeline from "../components/ProcessTimeline.astro";
import ImageComparison from "../components/ImageComparison.astro";

// Fetch all properties from the database
let dbProperties = [];
try {
  const response = await fetch("http://localhost:3001/api/properties");
  if (response.ok) {
    dbProperties = await response.json();
  }
} catch (e) {
  console.warn("Backend unavailable, no properties loaded:", e);
}

// Prepare arrays for UI sections
let exclusiveModels = dbProperties.filter((p: any) => p.is_exclusive);
if (exclusiveModels.length === 0) {
  exclusiveModels = dbProperties.slice(0, 4); // Fallback
}

let featuredModels = dbProperties.filter((p: any) => p.is_top);
if (featuredModels.length === 0) {
  featuredModels = dbProperties.slice(0, 6); // Fallback
}
---

<Layout title="Casas prefabricadas y modulares | Tayga Construcciones">
  <Hero />

  <main>
    <!-- FILOSOFÍA TAYGA -->
    <section class="philosophy">
      <div class="container philosophy-grid">
        <div class="philosophy-text">
          <span class="eyebrow">Filosofía Tayga</span>

          <h2>Arquitectura que respira con la naturaleza</h2>

          <p>
            Nuestras casas no solo se construyen en el entorno, sino que forman
            parte de él. Utilizamos madera sostenible certificada y técnicas de
            construcción pasiva para crear hogares que son refugios de
            bienestar, eficiencia y belleza atemporal.
          </p>

          <a href="/nosotros" class="text-link">
            Descubre nuestra historia →
          </a>
        </div>

        <div class="philosophy-media">
          <img src="/images/img_fondo1.jpg" alt="Interior de casa de madera" />

          <div class="media-caption">
            <span class="model">MODELO ALPINA</span>
            <strong>Interior calidez escandinava</strong>
          </div>
        </div>
      </div>
    </section>

    <!-- MODELOS EXCLUSIVOS -->
    <section class="models">
      <div class="container">
        <div class="models-header">
          <span class="eyebrow">Nuestra colección</span>
          <h2>Modelos exclusivos</h2>
          <p>Diseños pensados para habitar en armonía</p>
        </div>

        <div class="models-grid">
          {
            exclusiveModels.map((model: any) => (
              <a href={`/modelos/${model.id}`} class="model-card">
                <img
                  src={model.image_url || "/images/img_fondo1.jpg"}
                  alt={model.title}
                />
                <h3>{model.title}</h3>
                <span>
                  {model.area}m² – {model.bedrooms} Habitaciones
                </span>
              </a>
            ))
          }
          {
            exclusiveModels.length === 0 && (
              <p>No hay modelos disponibles en este momento.</p>
            )
          }
        </div>
      </div>
    </section>

    <section class="why-us">
      <div class="container">
        <header class="why-us-header">
          <h2>¿Por qué elegirnos?</h2>
          <span class="underline"></span>
        </header>

        <div class="why-us-grid">
          <article class="why-card">
            <div class="why-icon">🏡</div>
            <h3>Rapidez</h3>
            <p>
              Valoramos el tiempo de nuestros clientes y por eso entregamos los
              proyectos a tiempo, con procesos ágiles y bien definidos.
            </p>
          </article>

          <article class="why-card">
            <div class="why-icon">🏅</div>
            <h3>Calidad superior</h3>
            <p>
              Cuidamos cada detalle desde la selección de la madera hasta el
              último acabado de la vivienda.
            </p>
          </article>

          <article class="why-card">
            <div class="why-icon">🌿</div>
            <h3>Respetuosos con el medio ambiente</h3>
            <p>
              Utilizamos madera sostenible y sistemas constructivos eficientes y
              responsables con el entorno.
            </p>
          </article>

          <article class="why-card">
            <div class="why-icon">🔑</div>
            <h3>Llave en mano</h3>
            <p>
              Nos encargamos de todo el proceso, desde la idea inicial hasta la
              entrega final de la vivienda.
            </p>
          </article>

          <article class="why-card">
            <div class="why-icon">✏️</div>
            <h3>Personalización total</h3>
            <p>
              Adaptamos cada proyecto a tus necesidades y realizamos
              modificaciones sin complicaciones.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="top-products">
      <div class="container">
        <header class="top-products-header animate-on-scroll">
          <h2>Nuestros productos top</h2>
          <span class="underline"></span>
        </header>

        {/* TOP PRODUCTS SECTION DYNAMIC */}
        <div class="top-products-grid animate-on-scroll">
          {
            featuredModels.map((model: any) => (
              <article class="product-card">
                <div class="product-media">
                  <span class="badge-top">TOP</span>

                  <button class="fav-btn" aria-label="Favorito">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                    </svg>
                  </button>

                  <a href={`/modelos/${model.id}`} class="img-link">
                    <img
                      src={model.image_url || "/images/img_fondo1.jpg"}
                      alt={`Modelo ${model.title}`}
                      loading="lazy"
                    />
                  </a>
                </div>

                <h3>{model.title}</h3>

                <ul class="product-features">
                  <li>
                    <img
                      src="/images/habitaciones.svg"
                      alt="estancias"
                      width="16"
                      height="16"
                      style="color: currentColor;"
                    />{" "}
                    {model.bedrooms} estancias
                  </li>
                  <li>
                    <img
                      src="/images/superficie.svg"
                      alt="superficie"
                      width="16"
                      height="16"
                      style="color: currentColor;"
                    />{" "}
                    {model.area} m²
                  </li>
                </ul>

                <p class="price">
                  Precio desde{" "}
                  <strong>
                    €{Number(model.price).toLocaleString("es-ES")}
                  </strong>
                </p>

                <a href={`/modelos/${model.id}`} class="btn-outline">
                  Más información
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- NUEVO: COMPARATIVA -->
    <ComparisonSection />

    <!-- NUEVO: TIMELINE PROCESO -->
    <ProcessTimeline />

    <!-- NUEVO: SLIDER IMAGEN -->
    <ImageComparison />

    <section class="budget-section">
      <div class="container">
        <header class="budget-header">
          <span class="eyebrow">Contacto</span>
          <h2>Solicita tu presupuesto</h2>
          <span class="underline"></span>
        </header>

        <div class="budget-grid">
          <div class="budget-info">
            <h3>Tu refugio comienza con un plan</h3>
            <p>
              Déjanos tus datos y cuéntanos qué tienes en mente. Nuestro equipo
              te contactará para definir los detalles de tu futura casa de
              madera.
            </p>

            <ul class="budget-steps">
              <li><strong>01.</strong> Asesoramiento personalizado</li>
              <li><strong>02.</strong> Estudio técnico de viabilidad</li>
              <li><strong>03.</strong> Presupuesto detallado sin compromiso</li>
            </ul>

            <div class="simulator-cta">
              <a href="/presupuesto" class="btn-outline btn-simulator">
                Simular presupuesto
              </a>
              <p class="cta-note">Obtén una estimación rápida en 2 minutos</p>
            </div>
          </div>

          <div class="budget-form-wrapper">
            <form class="budget-form" id="quote-form">
              <div class="form-group">
                <input
                  type="text"
                  id="quote-name"
                  placeholder="Nombre completo"
                  required
                />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <input
                    type="email"
                    id="quote-email"
                    placeholder="Email"
                    required
                  />
                </div>
                <div class="form-group">
                  <input type="tel" id="quote-phone" placeholder="Teléfono" />
                </div>
              </div>

              <div class="form-group">
                <select id="quote-model" required>
                  <option value="" disabled selected
                    >Selecciona un modelo</option
                  >
                  <option value="modular">Serie Modular</option>
                  <option value="familiar">Residencia Familiar</option>
                  <option value="alpina">Cabaña Alpina</option>
                  <option value="studio">Garden Studio</option>
                </select>
              </div>

              <div class="form-group">
                <textarea
                  id="quote-message"
                  placeholder="Cuéntanos sobre tu proyecto..."
                  rows="4"
                  maxlength="500"></textarea>
                <div class="text-xs text-slate-500 mt-1 text-right">
                  <span id="quote-message-chars">0</span>/500
                </div>
              </div>

              <button type="submit" id="quote-submit-btn" class="btn-submit"
                >Enviar solicitud →</button
              >

              <div
                id="quote-feedback"
                class="hidden mt-4 p-3 rounded-xl text-sm font-bold text-center"
              >
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIOS -->
    <section class="testimonials-section">
      <div class="container">
        <header class="testimonials-header">
          <span class="eyebrow">Opiniones</span>
          <h2>Lo que dicen de nosotros</h2>
        </header>

        <div class="testimonials-grid">
          <!-- Card 1 -->
          <article class="testimonial-card">
            <div class="testimonial-rating">
              ★★★★☆ <span
                style="font-size: 0.8em; color: #999; margin-left: 5px;"
                >9/10</span
              >
            </div>
            <p class="testimonial-text">
              "La experiencia con Tayga ha sido increíble. Desde el diseño
              inicial hasta la entrega de llaves, todo fue fluido. La madera
              huele de maravilla y el aislamiento es perfecto."
            </p>
            <div class="testimonial-author">
              <div class="avatar">MJ</div>
              <div class="info">
                <strong>María José L.</strong>
                <span>Modelo Alpina</span>
              </div>
            </div>
          </article>

          <!-- Card 2 -->
          <article class="testimonial-card">
            <div class="testimonial-rating">
              ★★★★★ <span
                style="font-size: 0.8em; color: #999; margin-left: 5px;"
                >10/10</span
              >
            </div>
            <p class="testimonial-text">
              "Buscábamos un refugio sostenible y encontramos el hogar de
              nuestros sueños. La calidad de los acabados supera lo que
              imaginábamos por este precio."
            </p>
            <div class="testimonial-author">
              <div class="avatar">CR</div>
              <div class="info">
                <strong>Carlos Ruiz</strong>
                <span>Residencia Familiar</span>
              </div>
            </div>
          </article>

          <!-- Card 3 -->
          <article class="testimonial-card">
            <div class="testimonial-rating">
              ★★★★★ <span
                style="font-size: 0.8em; color: #999; margin-left: 5px;"
                >10/10</span
              >
            </div>
            <p class="testimonial-text">
              "El equipo de montaje fue súper profesional y rápido. En cuestión
              de semanas teníamos nuestra casa lista. Muy recomendables."
            </p>
            <div class="testimonial-author">
              <div class="avatar">AG</div>
              <div class="info">
                <strong>Ana García</strong>
                <span>Garden Studio</span>
              </div>
            </div>
          </article>

          <!-- Card 4 -->
          <article class="testimonial-card">
            <div class="testimonial-rating">
              ★★★★☆ <span
                style="font-size: 0.8em; color: #999; margin-left: 5px;"
                >8/10</span
              >
            </div>
            <p class="testimonial-text">
              "Muy contentos con el resultado final. Hubo un pequeño retraso por
              lluvias, pero la comunicación fue excelente en todo momento."
            </p>
            <div class="testimonial-author">
              <div class="avatar">PR</div>
              <div class="info">
                <strong>Pedro Rodríguez</strong>
                <span>Serie Modular</span>
              </div>
            </div>
          </article>

          <!-- Card 5 -->
          <article class="testimonial-card">
            <div class="testimonial-rating">
              ★★★★★ <span
                style="font-size: 0.8em; color: #999; margin-left: 5px;"
                >10/10</span
              >
            </div>
            <p class="testimonial-text">
              "Simplemente espectacular. La eficiencia energética se nota desde
              el primer día. Gracias a todo el equipo de Tayga."
            </p>
            <div class="testimonial-author">
              <div class="avatar">LM</div>
              <div class="info">
                <strong>Lucía M.</strong>
                <span>Modelo Alpina</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script src="../scripts/testimonials.js"></script>

<script is:inline>
  const quoteForm = document.getElementById("quote-form");
  const messageInput = document.getElementById("quote-message");
  const charsCounter = document.getElementById("quote-message-chars");
  const feedbackBox = document.getElementById("quote-feedback");
  const submitBtn = document.getElementById("quote-submit-btn");

  if (messageInput && charsCounter) {
    messageInput.addEventListener("input", () => {
      charsCounter.textContent = messageInput.value.length;
    });
  }

  if (quoteForm) {
    quoteForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const name = document.getElementById("quote-name").value;
      const email = document.getElementById("quote-email").value;
      const phone = document.getElementById("quote-phone").value;
      const model = document.getElementById("quote-model").value;
      const message = document.getElementById("quote-message").value;

      submitBtn.disabled = true;
      submitBtn.innerHTML = "Enviando...";
      feedbackBox.classList.add("hidden");
      feedbackBox.classList.remove(
        "bg-green-100",
        "text-green-700",
        "bg-red-100",
        "text-red-700",
      );

      try {
        const response = await fetch("http://localhost:3001/api/clients", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name, email, phone, model, message }),
        });

        const data = await response.json();

        feedbackBox.classList.remove("hidden");
        if (response.ok) {
          feedbackBox.classList.add("bg-green-100", "text-green-700");
          feedbackBox.textContent =
            "¡Solicitud enviada con éxito! Nos pondremos en contacto pronto.";
          quoteForm.reset();
          charsCounter.textContent = "0";
        } else {
          feedbackBox.classList.add("bg-red-100", "text-red-700");
          feedbackBox.textContent =
            data.error || "Hubo un error al enviar la solicitud.";
        }
      } catch (error) {
        feedbackBox.classList.remove("hidden");
        feedbackBox.classList.add("bg-red-100", "text-red-700");
        feedbackBox.textContent =
          "Error de conexión. Por favor, inténtalo más tarde.";
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = "Enviar solicitud →";
      }
    });
  }
</script>
